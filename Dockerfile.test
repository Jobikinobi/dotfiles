FROM ubuntu:24.04

# Avoid interactive prompts during package install
ENV DEBIAN_FRONTEND=noninteractive

# Install essentials + Homebrew Linux prerequisites
RUN apt-get update && apt-get install -y \
    build-essential \
    ca-certificates \
    curl \
    file \
    git \
    iptables \
    locales \
    openssh-server \
    procps \
    sudo \
    zsh \
    && rm -rf /var/lib/apt/lists/*

# Copy Tailscale binaries from official image (per Tailscale docs)
COPY --from=docker.io/tailscale/tailscale:stable /usr/local/bin/tailscaled /usr/local/bin/tailscaled
COPY --from=docker.io/tailscale/tailscale:stable /usr/local/bin/tailscale /usr/local/bin/tailscale
RUN mkdir -p /var/run/tailscale /var/cache/tailscale /var/lib/tailscale

# Set up locale (zsh/p10k need UTF-8)
RUN locale-gen en_US.UTF-8
ENV LANG=en_US.UTF-8

# Create a non-root user (chezmoi expects a real user, not root)
RUN useradd -m -s /bin/zsh jth \
    && echo "jth ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Set up SSH
RUN mkdir /var/run/sshd \
    && echo "PermitUserEnvironment yes" >> /etc/ssh/sshd_config

# Allow SSH via key (we'll inject the public key at run time)
RUN mkdir -p /home/jth/.ssh && chown jth:jth /home/jth/.ssh && chmod 700 /home/jth/.ssh

# Install chezmoi as jth
USER jth
WORKDIR /home/jth
RUN sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$HOME/.local/bin"
ENV PATH="/home/jth/.local/bin:${PATH}"

# Initialize dotfiles and install core stack
# chezmoi init clones the repo, apply deploys configs + runs install scripts
# The install script installs Homebrew + core Brewfile (bat, helix, fzf, etc.)
RUN chezmoi init --apply --no-tty Jobikinobi
ENV PATH="/home/linuxbrew/.linuxbrew/bin:${PATH}"

# Switch back to root for entrypoint
USER root

# Copy entrypoint script
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 22
ENTRYPOINT ["/entrypoint.sh"]
