#!/bin/bash
# Install packages from Brewfile (runs AFTER files are deployed so Brewfiles exist)

# Ensure brew is in PATH
{{- if eq .chezmoi.os "darwin" }}
eval "$(/opt/homebrew/bin/brew shellenv)" 2>/dev/null || eval "$(/usr/local/bin/brew shellenv)" 2>/dev/null
{{- else }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)" 2>/dev/null
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# macOS: full Brewfile (all tools, casks, GUI apps)
if [[ -f "$HOME/.Brewfile" ]]; then
  echo "→ Installing packages from Brewfile..."
  brew bundle --file="$HOME/.Brewfile"
fi
{{- else }}
# Linux: core Brewfile only (cross-platform CLI essentials)
if [[ -f "$HOME/.Brewfile.core" ]]; then
  echo "→ Installing core packages..."
  brew bundle --file="$HOME/.Brewfile.core"
fi
{{- end }}

# ── Node + Claude Code (cross-platform, needs fnm from brew) ────────────────
if command -v fnm &>/dev/null; then
  eval "$(fnm env)"
  if ! command -v node &>/dev/null; then
    echo "→ Installing Node LTS..."
    fnm install --lts
    fnm default lts-latest
    echo "✓ Node installed ($(node --version))"
  fi

  if ! npm list -g @anthropic-ai/claude-code &>/dev/null; then
    echo "→ Installing Claude Code..."
    npm install -g @anthropic-ai/claude-code
    echo "✓ Claude Code installed"
  else
    echo "✓ Claude Code already installed"
  fi
fi
