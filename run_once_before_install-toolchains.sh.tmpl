#!/bin/bash
set -e

# ══════════════════════════════════════════════════════════════════════════════
# Tailscale — cross-platform (runs on macOS and Linux)
# ══════════════════════════════════════════════════════════════════════════════

if ! command -v tailscale &>/dev/null; then
{{- if eq .chezmoi.os "darwin" }}
  echo "→ Tailscale: install via 'brew install --cask tailscale' or Brewfile"
{{- else }}
  echo "→ Installing Tailscale..."
  curl -fsSL https://tailscale.com/install.sh | sh
  echo "✓ Tailscale installed"
{{- end }}
fi

{{- if ne .chezmoi.os "darwin" }}
# On Linux, start tailscaled and join the tailnet if an auth key is available
if command -v tailscale &>/dev/null; then
  if ! tailscale status &>/dev/null; then
    sudo systemctl enable --now tailscaled 2>/dev/null || true
    if command -v doppler &>/dev/null; then
      TS_AUTHKEY="$(doppler secrets get TAILSCALE_AUTH_KEY --plain -p backend -c prd 2>/dev/null)" || true
      if [[ -n "$TS_AUTHKEY" ]]; then
        echo "→ Joining tailnet..."
        sudo tailscale up --authkey="$TS_AUTHKEY" --ssh
        echo "✓ Joined tailnet with Tailscale SSH enabled"
      else
        echo "⚠ Tailscale installed but no auth key — run 'sudo tailscale up' manually"
      fi
    else
      echo "⚠ Tailscale installed but Doppler not available — run 'sudo tailscale up' manually"
    fi
  else
    echo "✓ Tailscale already connected"
  fi
fi
{{- end }}

# ══════════════════════════════════════════════════════════════════════════════
# Node + Claude Code — cross-platform
# ══════════════════════════════════════════════════════════════════════════════

if command -v fnm &>/dev/null; then
  eval "$(fnm env)"
  if ! command -v node &>/dev/null; then
    echo "→ Installing Node LTS..."
    fnm install --lts
    fnm default lts-latest
    echo "✓ Node installed ($(node --version))"
  fi

  if ! npm list -g @anthropic-ai/claude-code &>/dev/null; then
    echo "→ Installing Claude Code..."
    npm install -g @anthropic-ai/claude-code
    echo "✓ Claude Code installed"
  else
    echo "✓ Claude Code already installed"
  fi
fi

{{- if eq .chezmoi.os "darwin" }}
# ══════════════════════════════════════════════════════════════════════════════
# macOS-only toolchains
# ══════════════════════════════════════════════════════════════════════════════

export PATH="/opt/homebrew/bin:$PATH"

# ── Go ───────────────────────────────────────────────────────────────────────
if ! command -v go &>/dev/null; then
  echo "→ Installing Go..."
  brew install go
else
  echo "✓ Go already installed ($(go version))"
fi

# ── Rust (via rustup) ────────────────────────────────────────────────────────
if ! command -v rustup &>/dev/null; then
  echo "→ Installing Rust via rustup..."
  brew install rustup
  rustup-init -y --no-modify-path
  source "$HOME/.cargo/env"
  echo "✓ Rust installed ($(rustc --version))"
else
  echo "✓ Rust already installed ($(rustc --version))"
fi

# ── Node (via fnm) ──────────────────────────────────────────────────────────
if ! command -v fnm &>/dev/null; then
  echo "→ Installing fnm (Fast Node Manager)..."
  brew install fnm
fi

if ! command -v node &>/dev/null; then
  echo "→ Installing Node LTS..."
  eval "$(fnm env)"
  fnm install --lts
  fnm default lts-latest
  echo "✓ Node installed ($(node --version))"
else
  echo "✓ Node already installed ($(node --version))"
fi

# ── uv (Python package manager) ──────────────────────────────────────────────
if ! command -v uv &>/dev/null; then
  echo "→ Installing uv..."
  brew install uv
  echo "✓ uv installed"
else
  echo "✓ uv already installed ($(uv --version))"
fi

# ── npm global tools ─────────────────────────────────────────────────────────
eval "$(fnm env)"

NPM_TOOLS=(
  "@anthropic-ai/claude-code"   # Claude Code
  "wrangler"                    # Cloudflare Wrangler
  "ctx7"                        # Context7 documentation CLI
  "@mem0/cli"                   # Mem0 AI memory layer
)

for pkg in "${NPM_TOOLS[@]}"; do
  tool_name="${pkg##*/}"        # strip scope prefix
  if ! npm list -g "$pkg" &>/dev/null; then
    echo "→ Installing $pkg..."
    npm install -g "$pkg"
    echo "✓ $tool_name installed"
  else
    echo "✓ $tool_name already installed"
  fi
done

# ── Supabase CLI ─────────────────────────────────────────────────────────────
if ! command -v supabase &>/dev/null; then
  echo "→ Installing Supabase CLI..."
  brew install supabase/tap/supabase
  echo "✓ Supabase CLI installed"
else
  echo "✓ Supabase CLI already installed"
fi

# ── Doppler (secrets management) ─────────────────────────────────────────────
if ! command -v doppler &>/dev/null; then
  echo "→ Installing Doppler..."
  brew install doppler
  echo "✓ Doppler installed"
else
  echo "✓ Doppler already installed"
fi
{{- end }}
